<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Busca nos Diários · Observatório Roraima</title>
    <meta name="description" content="Busque nomes e termos em todos os diários oficiais do MPRR e do TJRR arquivados pelo Observatório Roraima desde 2021.">
    {% if url_canonica %}
    <link rel="canonical" href="{{ url_canonica }}">
    <meta property="og:title" content="Busca nos Diários · Observatório Roraima">
    <meta property="og:description" content="Busque nomes e termos em todos os diários oficiais do MPRR e do TJRR desde 2021.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ url_canonica }}">
    <meta property="og:locale" content="pt_BR">
    <meta property="og:site_name" content="Observatório Roraima">
    <meta name="twitter:card" content="summary">
    {% endif %}
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='4' fill='%230F2A3D'/%3E%3Ctext x='16' y='24' font-family='Georgia,serif' font-size='22' font-weight='bold' text-anchor='middle' fill='%23fafafa'%3EO%3C/text%3E%3C/svg%3E">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,ital,wght@9..144,0,400;9..144,0,600;9..144,0,700;9..144,1,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --cor-primaria: #0F2A3D;
            --cor-primaria-apoio: #1D4E6B;
            --cor-cta: #1E6B4F;
            --cor-fundo: #FAF8F4;
            --cor-superficie: #FFFFFF;
            --cor-texto: #1A1A1A;
            --cor-texto-sec: #5C6670;
            --cor-dado: #B07D2B;
            --cor-dado-escuro: #8A5F17;
            --cor-em-breve: #8A99A8;
            --cor-mprr: #c8102e;
            --cor-tjrr: #1d4e89;
            --cor-secundaria: var(--cor-texto-sec);
            --cor-divisa: #E3DDD2;
            --cor-rule: var(--cor-primaria-apoio);
            --max-largura: 760px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--cor-fundo);
            color: var(--cor-texto);
            line-height: 1.5;
            padding: 0 1rem;
        }

        a { color: inherit; }

        .skip-link {
            position: absolute;
            left: -9999px;
            top: 0;
            background: var(--cor-primaria);
            color: var(--cor-fundo);
            padding: 0.6rem 1rem;
            font-size: 0.85rem;
            z-index: 100;
        }

        .skip-link:focus { left: 0.5rem; top: 0.5rem; }

        .pagina {
            max-width: var(--max-largura);
            margin: 0 auto;
            padding: 2rem 0 4rem;
        }

        header.masthead {
            text-align: center;
            border-bottom: 3px double var(--cor-primaria);
            padding-bottom: 1.2rem;
            margin-bottom: 2rem;
        }

        .masthead .kicker {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--cor-secundaria);
            margin-bottom: 0.4rem;
        }

        .masthead h1 {
            font-family: 'Fraunces', Georgia, serif;
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--cor-primaria);
        }

        .masthead .voltar {
            display: inline-block;
            margin-top: 0.6rem;
            font-size: 0.85rem;
            color: var(--cor-secundaria);
            text-decoration: none;
        }

        .masthead .voltar:hover { color: var(--cor-rule); }

        /* ============ FORM DE BUSCA ============ */
        #form-busca {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }

        #form-busca input[type="search"] {
            flex: 1;
            font-family: 'Inter', sans-serif;
            font-size: 1.05rem;
            padding: 0.75rem 1rem;
            border: 1.5px solid var(--cor-primaria);
            border-radius: 4px;
            background: var(--cor-superficie);
        }

        #form-busca input[type="search"]:focus {
            outline: 2px solid var(--cor-rule);
            outline-offset: 1px;
        }

        button.principal {
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            padding: 0.75rem 1.4rem;
            background: var(--cor-cta);
            color: var(--cor-superficie);
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        button.principal:hover { background: var(--cor-primaria-apoio); }

        .dica {
            font-size: 0.8rem;
            color: var(--cor-secundaria);
            margin-bottom: 2rem;
        }

        /* ============ ESTADOS ============ */
        .estado { margin: 2.5rem 0; text-align: center; color: var(--cor-secundaria); }
        .oculto { display: none !important; }

        #contagem {
            font-family: 'Fraunces', Georgia, serif;
            font-size: 1.15rem;
            color: var(--cor-primaria);
            margin: 1.5rem 0 1rem;
            border-bottom: 1px solid var(--cor-divisa);
            padding-bottom: 0.6rem;
        }

        /* ============ RESULTADOS ============ */
        article.resultado {
            border-bottom: 1px solid var(--cor-divisa);
            padding: 1.1rem 0;
        }

        .resultado .meta {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--cor-secundaria);
            margin-bottom: 0.45rem;
        }

        .resultado .meta .orgao {
            font-weight: 500;
            padding: 0.1rem 0.45rem;
            border-radius: 3px;
            color: #fff;
            margin-right: 0.5rem;
        }

        .resultado .meta .orgao.mprr { background: var(--cor-mprr); }
        .resultado .meta .orgao.tjrr { background: var(--cor-tjrr); }

        .resultado .trecho {
            font-size: 0.95rem;
            color: var(--cor-texto);
        }

        .resultado .trecho em {
            font-style: normal;
            font-weight: 600;
            background: #fff3b8;
            padding: 0 0.1rem;
        }

        .resultado .acoes { margin-top: 0.55rem; }

        .resultado .acoes a {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--cor-rule);
            text-decoration: none;
        }

        .resultado .acoes a:hover { text-decoration: underline; }

        /* ============ GATE / CADASTRO ============ */
        #gate {
            margin: 2rem 0;
            border: 1.5px solid var(--cor-primaria);
            border-radius: 6px;
            padding: 1.6rem;
            background: var(--cor-superficie);
        }

        #gate h2 {
            font-family: 'Fraunces', Georgia, serif;
            font-size: 1.3rem;
            color: var(--cor-primaria);
            margin-bottom: 0.4rem;
        }

        #gate p.explicacao {
            font-size: 0.9rem;
            color: var(--cor-secundaria);
            margin-bottom: 1.2rem;
        }

        #placeholders .ph {
            border-bottom: 1px solid var(--cor-divisa);
            padding: 1.1rem 0;
            font-size: 0.95rem;
            color: var(--cor-secundaria);
            filter: blur(6px) saturate(0.7);
            user-select: none;
            pointer-events: none;
        }

        a.botao-link {
            display: inline-block;
            text-decoration: none;
            text-align: center;
        }

        #botao-mais { margin: 1.5rem auto; display: block; }

        footer {
            margin-top: 3rem;
            border-top: 3px double var(--cor-primaria);
            padding-top: 1rem;
            text-align: center;
            font-size: 0.8rem;
            color: var(--cor-secundaria);
        }

        @media (max-width: 600px) {
            #form-busca { flex-direction: column; }
            .masthead h1 { font-size: 1.7rem; }
        }
    </style>
</head>
<body>
    <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>
    <div class="pagina">
        <header class="masthead">
            <p class="kicker">Observatório Roraima</p>
            <h1>Busca nos Diários</h1>
            <a class="voltar" href="{{ url_indice }}">← Voltar ao jornal</a>
        </header>

        <main id="conteudo">
            <form id="form-busca" role="search">
                <input type="search" id="campo-busca" name="q" maxlength="200" required
                       placeholder="Nome de pessoa, empresa ou termo…"
                       aria-label="Termo de busca">
                <button class="principal" type="submit">Buscar</button>
            </form>
            <p class="dica">Busca em todas as edições do MPRR e do TJRR desde 2021. Acentos são opcionais: "José" e "jose" encontram o mesmo resultado.</p>

            <div id="estado-carregando" class="estado oculto">Buscando…</div>
            <div id="estado-vazio" class="estado oculto">Nenhuma ocorrência encontrada. Tente outra grafia ou menos palavras.</div>
            <div id="estado-erro" class="estado oculto">Não foi possível completar a busca agora. Tente novamente em instantes.</div>

            <div id="area-resultados" class="oculto">
                <p id="contagem"></p>
                <div id="lista-resultados"></div>
                <button id="botao-mais" class="principal oculto" type="button">Carregar mais resultados</button>
            </div>

            <div id="placeholders" class="oculto" aria-hidden="true"></div>

            <div id="gate" class="oculto">
                <h2>Veja todas as ocorrências</h2>
                <p class="explicacao"><span id="gate-contador"></span> O acesso completo é gratuito — sem cartão de crédito.</p>
                <a id="botao-cadastro" class="principal botao-link" href="cadastro.html">Visualizar mais resultados</a>
            </div>
        </main>

        <footer>
            <p>Observatório Roraima · Diário editorial automatizado · <a href="{{ url_sobre }}">Sobre</a> · <a href="{{ url_privacidade }}">Privacidade</a></p>
        </footer>
    </div>

    <script>
    (function () {
        "use strict";
        var API = "{{ busca_api_url }}";
        var CHAVE_TOKEN = "obs_busca_token";
        var CHAVE_TERMOS = "obs_termos_sessao";
        var CHAVE_SESSAO = "obs_sessao_id";
        // texto dos placeholders: SEMPRE fictício — nenhum dado real
        // bloqueado chega ao cliente (o corte é no servidor)
        var TEXTO_FICTICIO = "Conteúdo reservado — órgão, data da edição e o trecho com o termo aparecem aqui após o acesso gratuito. ";
        var consultaAtual = "";
        var offsetAtual = 0;
        var TAMANHO_PAGINA = 20;
        var MAX_PLACEHOLDERS = 6;

        var el = function (id) { return document.getElementById(id); };
        var mostrar = function (id) { el(id).classList.remove("oculto"); };
        var esconder = function (id) { el(id).classList.add("oculto"); };

        function token() { return localStorage.getItem(CHAVE_TOKEN); }

        function sessaoId() {
            var id = sessionStorage.getItem(CHAVE_SESSAO);
            if (!id) {
                id = Math.random().toString(36).slice(2) + Date.now().toString(36);
                sessionStorage.setItem(CHAVE_SESSAO, id);
            }
            return id;
        }

        function evento(tipo) {
            if (!navigator.sendBeacon) { return; }
            var corpo = JSON.stringify({ tipo: tipo, sessao: sessaoId() });
            navigator.sendBeacon(API + "/eventos", new Blob([corpo], { type: "application/json" }));
        }

        function guardarTermo(q) {
            var termos = [];
            try { termos = JSON.parse(sessionStorage.getItem(CHAVE_TERMOS)) || []; } catch (e) { termos = []; }
            if (termos.indexOf(q) === -1) {
                termos.push(q);
                sessionStorage.setItem(CHAVE_TERMOS, JSON.stringify(termos.slice(-50)));
            }
        }

        function formatarData(iso) {
            var p = iso.split("-");
            return p[2] + "/" + p[1] + "/" + p[0];
        }

        function renderResultado(r) {
            var art = document.createElement("article");
            art.className = "resultado";

            var meta = document.createElement("p");
            meta.className = "meta";
            var orgao = document.createElement("span");
            orgao.className = "orgao " + r.orgao;
            orgao.textContent = r.orgao.toUpperCase();
            meta.appendChild(orgao);
            var info = "Edição de " + formatarData(r.data_edicao);
            if (r.numero) { info += " · nº " + r.numero; }
            info += " · pág. " + r.pagina;
            meta.appendChild(document.createTextNode(info));
            art.appendChild(meta);

            var trecho = document.createElement("p");
            trecho.className = "trecho";
            // único innerHTML da página: a API entrega o trecho já HTML-escapado,
            // com apenas <em> de highlight
            trecho.innerHTML = "… " + r.trecho_html + " …";
            art.appendChild(trecho);

            var acoes = document.createElement("p");
            acoes.className = "acoes";
            var link = document.createElement("a");
            link.href = r.url_pdf;
            link.target = "_blank";
            link.rel = "noopener";
            link.textContent = "Abrir o diário em PDF (pág. " + r.pagina + ") →";
            acoes.appendChild(link);
            art.appendChild(acoes);
            return art;
        }

        function gerarPlaceholders(quantos) {
            var alvo = el("placeholders");
            alvo.textContent = "";
            var n = Math.min(quantos, MAX_PLACEHOLDERS);
            for (var i = 0; i < n; i++) {
                var div = document.createElement("div");
                div.className = "ph";
                var repeticoes = 1 + Math.floor(Math.random() * 3);
                div.textContent = new Array(repeticoes + 1).join(TEXTO_FICTICIO);
                alvo.appendChild(div);
            }
            mostrar("placeholders");
        }

        function renderResposta(corpo, anexar) {
            var lista = el("lista-resultados");
            if (!anexar) { lista.textContent = ""; }
            corpo.resultados.forEach(function (r) {
                lista.appendChild(renderResultado(r));
            });

            if (corpo.total_diarios === 0) {
                esconder("area-resultados");
                esconder("gate");
                esconder("placeholders");
                mostrar("estado-vazio");
                return;
            }

            var contagem = el("contagem");
            contagem.textContent = corpo.total_ocorrencias + " ocorrência(s) em " +
                corpo.total_diarios + " diário(s)";
            if (corpo.parcial) {
                contagem.textContent += " — mostrando os " + corpo.resultados.length +
                    " mais recentes";
            }
            mostrar("area-resultados");

            if (corpo.parcial && corpo.total_diarios > corpo.resultados.length) {
                var ocultos = corpo.total_ocorrencias - corpo.resultados.length;
                if (ocultos < 1) { ocultos = corpo.total_diarios - corpo.resultados.length; }
                gerarPlaceholders(corpo.total_diarios - corpo.resultados.length);
                el("gate-contador").textContent = "Mais " + ocultos + " ocorrências encontradas.";
                el("botao-cadastro").href = "cadastro.html?q=" +
                    encodeURIComponent(consultaAtual) + "&total=" + corpo.total_diarios;
                mostrar("gate");
                esconder("botao-mais");
                evento("gate_view");
            } else {
                esconder("gate");
                esconder("placeholders");
                var exibidos = offsetAtual + corpo.resultados.length;
                if (!corpo.parcial && exibidos < corpo.total_diarios) {
                    mostrar("botao-mais");
                } else {
                    esconder("botao-mais");
                }
            }
        }

        function buscar(q, offset, anexar, jaTentouSemToken) {
            esconder("estado-vazio");
            esconder("estado-erro");
            if (!anexar) {
                esconder("area-resultados");
                esconder("gate");
                esconder("placeholders");
            }
            mostrar("estado-carregando");

            var headers = { "Content-Type": "application/json" };
            var t = token();
            if (t) { headers["X-Sessao"] = t; }

            fetch(API + "/buscar", {
                method: "POST",
                headers: headers,
                body: JSON.stringify({ q: q, offset: offset })
            }).then(function (resp) {
                if (resp.status === 401) {
                    // sessão expirada/inválida: limpa e refaz como visitante
                    localStorage.removeItem(CHAVE_TOKEN);
                    if (!jaTentouSemToken) { buscar(q, 0, false, true); }
                    return null;
                }
                if (!resp.ok) { throw new Error("HTTP " + resp.status); }
                return resp.json();
            }).then(function (corpo) {
                esconder("estado-carregando");
                if (corpo) { renderResposta(corpo, anexar); }
            }).catch(function () {
                esconder("estado-carregando");
                mostrar("estado-erro");
            });
        }

        el("form-busca").addEventListener("submit", function (ev) {
            ev.preventDefault();
            consultaAtual = el("campo-busca").value.trim();
            offsetAtual = 0;
            if (consultaAtual) {
                guardarTermo(consultaAtual);
                evento("busca_exec");
                buscar(consultaAtual, 0, false, false);
            }
        });

        el("botao-mais").addEventListener("click", function () {
            offsetAtual += TAMANHO_PAGINA;
            buscar(consultaAtual, offsetAtual, true, false);
        });

        // chegando do cadastro: ?q= refaz a busca já desbloqueada
        var params = new URLSearchParams(window.location.search);
        var qInicial = (params.get("q") || "").trim();
        if (qInicial) {
            el("campo-busca").value = qInicial;
            consultaAtual = qInicial;
            buscar(qInicial, 0, false, false);
        }
    })();
    </script>
    {% if analytics_token %}
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "{{ analytics_token }}"}'></script>
    {% endif %}
</body>
</html>

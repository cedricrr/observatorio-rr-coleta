<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Observatório Roraima</title>
    <meta name="description" content="Diário editorial dos órgãos públicos de Roraima — destaques das últimas edições.">
    {% if url_canonica %}
    <link rel="canonical" href="{{ url_canonica }}">
    <meta property="og:title" content="Observatório Roraima">
    <meta property="og:description" content="Diário editorial dos órgãos públicos de Roraima — destaques das últimas edições.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ url_canonica }}">
    <meta property="og:locale" content="pt_BR">
    <meta property="og:site_name" content="Observatório Roraima">
    <meta name="twitter:card" content="summary">
    {% endif %}
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='4' fill='%23c8102e'/%3E%3Ctext x='16' y='24' font-family='Georgia,serif' font-size='22' font-weight='bold' text-anchor='middle' fill='%23fafafa'%3EO%3C/text%3E%3C/svg%3E">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,ital,wght@9..144,0,400;9..144,0,600;9..144,0,700;9..144,1,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --cor-primaria: #1a1a1a;
            --cor-texto: #2c2c2c;
            --cor-secundaria: #666;
            --cor-fundo: #fafafa;
            --cor-divisa: #e0e0e0;
            --cor-rule: #c8102e;
            --max-largura: 1180px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--cor-fundo);
            color: var(--cor-texto);
            line-height: 1.5;
            padding: 0 1rem;
        }

        a { color: inherit; }

        /* ============ ACESSIBILIDADE ============ */
        .skip-link {
            position: absolute;
            left: -9999px;
            top: 0;
            background: var(--cor-primaria);
            color: var(--cor-fundo);
            padding: 0.6rem 1rem;
            font-family: 'Inter', sans-serif;
            font-size: 0.85rem;
            z-index: 100;
        }

        .skip-link:focus {
            left: 0.5rem;
            top: 0.5rem;
        }

        a:focus-visible,
        .botao-diarios:focus-visible {
            outline: 2px solid var(--cor-rule);
            outline-offset: 2px;
        }

        .container {
            max-width: var(--max-largura);
            margin: 0 auto;
            padding: 1.5rem 0 3rem;
        }

        /* ============ HEADER ============ */
        header.masthead {
            border-top: 3px solid var(--cor-rule);
            border-bottom: 1px solid var(--cor-primaria);
            padding: 1.25rem 0 1rem;
            text-align: center;
            margin-bottom: 1.5rem;
        }

        header.masthead h1.wordmark {
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 700;
            font-size: clamp(2rem, 5vw, 3.25rem);
            color: var(--cor-primaria);
            letter-spacing: -0.025em;
            line-height: 1.05;
        }

        header.masthead .subhead {
            font-family: 'Fraunces', Georgia, serif;
            font-style: italic;
            font-weight: 400;
            font-size: 1.05rem;
            color: var(--cor-secundaria);
            margin: 0.4rem 0 0.6rem;
        }

        header.masthead .meta {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--cor-secundaria);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        /* ============ HERO ============ */
        section.hero {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            padding: 1.5rem 0 2rem;
        }

        section.hero .kicker {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 500;
            font-size: 0.72rem;
            color: var(--cor-rule);
            text-transform: uppercase;
            letter-spacing: 0.12em;
            margin-bottom: 0.5rem;
        }

        section.hero .kicker .sep {
            color: var(--cor-secundaria);
            margin: 0 0.5rem;
        }

        section.hero h2.manchete-hero {
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 700;
            font-size: clamp(1.75rem, 4vw, 2.85rem);
            line-height: 1.05;
            letter-spacing: -0.015em;
            color: var(--cor-primaria);
            margin-bottom: 0.75rem;
        }

        section.hero h2.manchete-hero a {
            text-decoration: none;
            transition: color .15s ease;
        }

        section.hero h2.manchete-hero a:hover {
            color: var(--cor-rule);
        }

        section.hero .lede {
            font-family: 'Fraunces', Georgia, serif;
            font-style: italic;
            font-weight: 400;
            font-size: 1.1rem;
            color: var(--cor-texto);
            line-height: 1.45;
            display: -webkit-box;
            -webkit-line-clamp: 4;
            line-clamp: 4;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        section.hero .meta-hero {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
            color: var(--cor-secundaria);
            margin-top: 1rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.85rem;
            align-items: center;
        }

        section.hero .meta-hero .valor {
            color: var(--cor-primaria);
            font-weight: 500;
        }

        section.hero .meta-hero .link-pdf {
            border-bottom: 1px dotted var(--cor-secundaria);
            text-decoration: none;
            transition: color .15s ease;
        }

        section.hero .meta-hero .link-pdf:hover {
            color: var(--cor-primaria);
            border-bottom-color: var(--cor-primaria);
        }

        /* ilustração temática na coluna direita do hero */
        section.hero .lado-direito {
            margin-top: 1.5rem;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        section.hero .ilustra-svg {
            width: 100%;
            max-width: 220px;
            height: auto;
        }

        /* divisor entre hero e grid */
        hr.regra {
            border: none;
            border-top: 1px solid var(--cor-primaria);
            margin: 0;
        }

        /* ============ GRID DE DESTAQUES ============ */
        section.grid-destaques {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0;
            padding: 1.5rem 0 2rem;
        }

        .card-destaque {
            border-top: 1px solid var(--cor-divisa);
            padding: 1.25rem 0;
        }

        .card-destaque:first-child {
            border-top: none;
            padding-top: 0;
        }

        .card-destaque .kicker {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 500;
            font-size: 0.7rem;
            color: var(--cor-rule);
            text-transform: uppercase;
            letter-spacing: 0.12em;
            margin-bottom: 0.4rem;
        }

        .card-destaque .kicker .sep {
            color: var(--cor-secundaria);
            margin: 0 0.4rem;
        }

        .card-destaque h3.manchete-card {
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 600;
            font-size: 1.2rem;
            line-height: 1.2;
            color: var(--cor-primaria);
            margin-bottom: 0.5rem;
        }

        .card-destaque h3.manchete-card a {
            text-decoration: none;
            transition: color .15s ease;
        }

        .card-destaque h3.manchete-card a:hover {
            color: var(--cor-rule);
        }

        .card-destaque .resumo-card {
            font-family: 'Inter', sans-serif;
            font-size: 0.92rem;
            color: var(--cor-texto);
            display: -webkit-box;
            -webkit-line-clamp: 3;
            line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-bottom: 0.5rem;
        }

        .card-destaque .meta-card {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            color: var(--cor-secundaria);
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
        }

        .card-destaque .meta-card .valor {
            color: var(--cor-primaria);
            font-weight: 500;
        }

        /* ============ LINKS PARA DIÁRIOS ============ */
        nav.nav-diarios {
            border-top: 1px solid var(--cor-primaria);
            padding-top: 1.5rem;
            margin-top: 1rem;
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }

        nav.nav-diarios .botao-diarios {
            display: block;
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 600;
            font-size: 1.05rem;
            color: var(--cor-primaria);
            text-decoration: none;
            border: 1px solid var(--cor-primaria);
            border-left: 4px solid var(--cor-rule);
            padding: 0.9rem 1.1rem;
            transition: color .15s ease, background-color .15s ease;
        }

        nav.nav-diarios .botao-diarios:hover {
            background: var(--cor-primaria);
            color: var(--cor-fundo);
            border-left-color: var(--cor-rule);
        }

        nav.nav-diarios .painel-busca {
            grid-column: 1 / -1;
            display: block;
            text-decoration: none;
            color: var(--cor-primaria);
            border: 1px solid var(--cor-primaria);
            border-left: 4px solid var(--cor-rule);
            padding: 1.1rem 1.2rem;
            transition: color .15s ease, background-color .15s ease;
        }

        nav.nav-diarios .painel-busca .titulo {
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 700;
            font-size: 1.25rem;
        }

        nav.nav-diarios .painel-busca .convite {
            font-size: 0.9rem;
            color: var(--cor-secundaria);
            margin-top: 0.2rem;
        }

        nav.nav-diarios .painel-busca .estatisticas {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem 1.5rem;
            margin-top: 0.7rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--cor-secundaria);
        }

        nav.nav-diarios .painel-busca:hover {
            background: var(--cor-primaria);
            color: var(--cor-fundo);
        }

        nav.nav-diarios .painel-busca:hover .convite,
        nav.nav-diarios .painel-busca:hover .estatisticas {
            color: var(--cor-fundo);
        }

        /* ============ EMPTY ============ */
        .empty-state {
            text-align: center;
            padding: 4rem 1rem;
            color: var(--cor-secundaria);
            font-family: 'Fraunces', Georgia, serif;
            font-style: italic;
            font-size: 1.05rem;
        }

        /* ============ FOOTER ============ */
        footer.jornal-rodape {
            margin-top: 3rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--cor-divisa);
            text-align: center;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            color: var(--cor-secundaria);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        /* ============ BREAKPOINTS ============ */
        @media (min-width: 768px) {
            section.grid-destaques {
                grid-template-columns: repeat(2, 1fr);
                column-gap: 2rem;
            }

            .card-destaque {
                border-top: 1px solid var(--cor-divisa);
                padding: 1.25rem 0;
            }

            .card-destaque:nth-child(-n+2) {
                border-top: none;
                padding-top: 0;
            }

            nav.nav-diarios {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            section.hero {
                grid-template-columns: 7fr 5fr;
                gap: 2.5rem;
            }

            section.hero .lado-direito {
                border-left: 1px solid var(--cor-divisa);
                padding-left: 2.5rem;
                margin-top: 0;
            }

            section.grid-destaques {
                grid-template-columns: repeat(3, 1fr);
            }

            .card-destaque:nth-child(-n+3) {
                border-top: none;
                padding-top: 0;
            }
        }

        /* ============ Zona de busca (Sessão 13.3) ============ */
        #zona-busca {
            margin: 1.6rem 0 2rem;
            padding-bottom: 1.6rem;
            border-bottom: 1px solid var(--cor-divisa, #e0e0e0);
        }

        #zona-busca .posicionamento {
            font-family: 'Fraunces', Georgia, serif;
            font-size: 1.15rem;
            color: var(--cor-primaria, #1a1a1a);
            margin-bottom: 0.8rem;
        }

        #zona-busca .form-busca-home {
            display: flex;
            gap: 0.5rem;
        }

        #zona-busca .form-busca-home input[type="search"] {
            flex: 1;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            padding: 0.7rem 1rem;
            border: 1.5px solid var(--cor-primaria, #1a1a1a);
            border-radius: 4px;
            background: #fff;
        }

        #zona-busca .form-busca-home button {
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            padding: 0.7rem 1.4rem;
            background: var(--cor-primaria, #1a1a1a);
            color: #fafafa;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        #zona-busca .jurisdicoes {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.8rem;
            padding: 0;
            font-size: 0.8rem;
        }

        #zona-busca .jurisdicoes li { display: inline-flex; }

        #zona-busca .jurisdicoes .pilula {
            font-family: 'JetBrains Mono', monospace;
            padding: 0.25rem 0.7rem;
            border: 1px solid var(--cor-divisa, #e0e0e0);
            border-radius: 999px;
            background: none;
            font-size: 0.75rem;
            cursor: pointer;
        }

        #zona-busca .jurisdicoes .ativa .pilula {
            background: var(--cor-primaria, #1a1a1a);
            color: #fafafa;
            border-color: var(--cor-primaria, #1a1a1a);
            cursor: default;
        }

        #zona-busca .jurisdicoes .pilula:disabled {
            color: #8a99a8;
            cursor: not-allowed;
        }

        #zona-busca .contadores-acervo {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 1.2rem;
            margin-top: 0.7rem;
            padding: 0;
            font-size: 0.78rem;
            color: var(--cor-secundaria, #666);
        }

        #form-interesse-estado {
            margin-top: 0.9rem;
            padding: 0.9rem 1rem;
            border: 1px solid var(--cor-divisa, #e0e0e0);
            border-radius: 6px;
            font-size: 0.85rem;
        }

        #form-interesse-estado input[type="text"],
        #form-interesse-estado input[type="email"] {
            width: 100%;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            padding: 0.45rem 0.7rem;
            margin: 0.25rem 0 0.6rem;
            border: 1px solid var(--cor-divisa, #e0e0e0);
            border-radius: 4px;
        }

        #form-interesse-estado .consent {
            display: flex;
            gap: 0.5rem;
            align-items: flex-start;
            margin: 0.4rem 0 0.8rem;
            color: var(--cor-secundaria, #666);
        }

        #reforco-busca {
            margin: 2.2rem 0 0;
            padding: 1.2rem 1.4rem;
            border: 1px solid var(--cor-divisa, #e0e0e0);
            border-radius: 6px;
            text-align: center;
            font-size: 0.95rem;
        }

        .oculto { display: none !important; }
    </style>
</head>
<body>
    <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>
    <div class="container">
        <header class="masthead">
            <h1 class="wordmark">Observatório Roraima</h1>
            <p class="subhead">Diário editorial dos órgãos públicos de Roraima</p>
            <p class="meta">
                {%- if data_ultima_formatada %}Última edição · {{ data_ultima_formatada }}{% else %}{{ total_edicoes }} {{ "edição" if total_edicoes == 1 else "edições" }}{% endif %}
            </p>
        </header>

        {% if url_busca %}
        <section id="zona-busca" aria-label="Busca no acervo de diários">
            <p class="posicionamento">Tudo o que o poder público de Roraima publica nos diários oficiais, pesquisável por nome.</p>
            <form class="form-busca-home" role="search" action="{{ url_busca }}" method="get">
                <input type="search" name="q" maxlength="200" required
                       placeholder="Pesquise um nome, empresa ou número de processo…"
                       aria-label="Termo de busca">
                <button type="submit">Buscar</button>
            </form>
            <ul class="jurisdicoes">
                <li class="ativa"><span class="pilula">Roraima</span></li>
                <li><button class="pilula" type="button" disabled>Amazonas · Em breve</button></li>
                <li><button class="pilula" type="button" disabled>Pará · Em breve</button></li>
                <li><button class="pilula" type="button" id="abrir-interesse" aria-expanded="false">Outros estados</button></li>
            </ul>
            {% if acervo %}
            <ul class="contadores-acervo">
                {% for f in acervo %}
                <li><strong>{{ f.total_formatado }}</strong>&nbsp;edições do {{ f.orgao }} · última em {{ f.ultima_edicao_formatada }}</li>
                {% endfor %}
            </ul>
            {% endif %}
            <form id="form-interesse-estado" class="oculto">
                <p>Quer o Observatório no seu estado? Deixe seu contato e avisaremos quando chegarmos lá.</p>
                <label for="interesse-uf">Estado</label>
                <input type="text" id="interesse-uf" maxlength="40" required placeholder="Amazonas">
                <label for="interesse-nome">Nome</label>
                <input type="text" id="interesse-nome" maxlength="120" required autocomplete="name">
                <label for="interesse-email">E-mail</label>
                <input type="email" id="interesse-email" required autocomplete="email">
                <div class="consent">
                    <input type="checkbox" id="interesse-consentimento" required>
                    <label for="interesse-consentimento">Autorizo o uso do meu e-mail para relatórios e notificações do Observatório Roraima, nos termos da LGPD.</label>
                </div>
                <button class="pilula" type="submit">Quero ser avisado</button>
                <p id="interesse-aviso" role="status"></p>
            </form>
        </section>
        {% endif %}

        <main id="conteudo">
        {% if hero and (hero.publicar | default(true)) %}
        <section class="hero">
            <div class="lado-esquerdo">
                <p class="kicker">
                    {{ hero.categoria }}<span class="sep">·</span>{{ hero.orgao }}
                </p>
                <h2 class="manchete-hero">
                    <a href="{{ hero.pdf_url }}" target="_blank" rel="noopener">{{ hero.manchete }}</a>
                </h2>
                {%- if hero.resumo %}
                <p class="lede">{{ hero.resumo }}</p>
                {%- endif %}
                <div class="meta-hero">
                    {%- if hero.valor_rs %}
                    <span class="valor">R$ {{ formatar_valor(hero.valor_rs) }}</span>
                    {%- endif %}
                    {%- if hero.data_edicao %}
                    <span class="data">{{ formatar_data(hero.data_edicao) }}</span>
                    {%- endif %}
                    {%- if hero.pdf_url %}
                    <a class="link-pdf" href="{{ hero.pdf_url }}" target="_blank" rel="noopener">diário oficial (PDF)</a>
                    {%- endif %}
                </div>
            </div>
            <aside class="lado-direito">
                {{ ilustracao_categoria(hero.categoria, hero.orgao) }}
            </aside>
        </section>
        <hr class="regra">
        {% endif %}

        {% if destaques %}
        <section class="grid-destaques">
            {% for d in destaques if d.publicar | default(true) %}
            <article class="card-destaque">
                <p class="kicker">
                    {{ d.categoria }}<span class="sep">·</span>{{ d.orgao }}
                </p>
                <h3 class="manchete-card">
                    <a href="{{ d.pdf_url }}" target="_blank" rel="noopener">{{ d.manchete }}</a>
                </h3>
                {%- if d.resumo %}
                <p class="resumo-card">{{ d.resumo }}</p>
                {%- endif %}
                <div class="meta-card">
                    {%- if d.valor_rs %}
                    <span class="valor">R$ {{ formatar_valor(d.valor_rs) }}</span>
                    {%- endif %}
                    {%- if d.data_edicao %}
                    <span class="data">{{ formatar_data(d.data_edicao) }}</span>
                    {%- endif %}
                </div>
            </article>
            {% endfor %}
        </section>
        {% endif %}

        {% if not hero and not destaques and total_edicoes == 0 %}
        <div class="empty-state">Nenhuma edição publicada ainda.</div>
        {% endif %}

        <nav class="nav-diarios">
            {% if url_busca %}
            <a class="painel-busca" href="{{ url_busca }}">
                <p class="titulo">Busca nos Diários</p>
                <p class="convite">Pesquise nomes e termos em todo o acervo{% if ano_inicio %} desde {{ ano_inicio }}{% endif %}.</p>
                {% if acervo %}
                <ul class="estatisticas">
                    {% for f in acervo %}
                    <li><strong>{{ f.orgao }}</strong> · {{ f.total_formatado }} diários · {{ f.ano_min }}–{{ f.ano_max }}</li>
                    {% endfor %}
                </ul>
                {% endif %}
            </a>
            {% endif %}
            <a class="botao-diarios" href="{{ url_diarios_mprr }}">Diários do MPRR</a>
            <a class="botao-diarios" href="{{ url_diarios_tjrr }}">Diários do TJRR</a>
        </nav>
        </main>

        {% if url_busca %}
        <section id="reforco-busca">
            <p>Procurando um nome específico? <a href="{{ url_busca }}">Pesquise no acervo completo de diários oficiais</a>{% if ano_inicio %} — edições desde {{ ano_inicio }}{% endif %}.</p>
        </section>
        {% endif %}

        <footer class="jornal-rodape">
            <p>Observatório Roraima · Diário editorial automatizado · <a href="{{ url_sobre }}">Sobre</a></p>
        </footer>
    </div>
{% if url_busca and busca_api_url %}
<script>
(function () {
    "use strict";
    var API = "{{ busca_api_url }}";
    var botao = document.getElementById("abrir-interesse");
    var form = document.getElementById("form-interesse-estado");
    if (!botao || !form) { return; }
    botao.addEventListener("click", function () {
        var aberto = !form.classList.toggle("oculto");
        botao.setAttribute("aria-expanded", aberto ? "true" : "false");
    });
    form.addEventListener("submit", function (ev) {
        ev.preventDefault();
        var aviso = document.getElementById("interesse-aviso");
        var corpo = {
            nome: document.getElementById("interesse-nome").value.trim(),
            email: document.getElementById("interesse-email").value.trim(),
            consentimentos: { relatorios: document.getElementById("interesse-consentimento").checked },
            termos: ["interesse_estado: " + document.getElementById("interesse-uf").value.trim()]
        };
        fetch(API + "/leads", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(corpo)
        }).then(function (resp) {
            if (!resp.ok) { throw new Error("HTTP " + resp.status); }
            form.reset();
            aviso.textContent = "Obrigado! Avisaremos quando o Observatório chegar ao seu estado.";
        }).catch(function () {
            aviso.textContent = "Não foi possível enviar agora. Confira os campos e tente de novo.";
        });
    });
})();
</script>
{% endif %}
{% if analytics_token %}
<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "{{ analytics_token }}"}'></script>
{% endif %}
</body>
</html>

R2_ACCOUNT_ID=your-value-here
R2_BUCKET_NAME=your-value-here
R2_PUBLIC_DOMAIN=your-value-here
R2_ACCESS_KEY_ID=your-value-here
R2_SECRET_ACCESS_KEY=your-value-here

# Anthropic API (Sessão 8 — pipeline editorial)
ANTHROPIC_API_KEY=your-value-here

# Notificação de falha do launchd (Ciclo 10.4) — webhook HTTP POST opcional.
# rodar_jornal.sh faz POST JSON {"text": "..."} aqui quando a rodada falha
# (exit != 0). Compatível com webhooks estilo Slack/Discord. Vazio = desativado.
WEBHOOK_URL=
